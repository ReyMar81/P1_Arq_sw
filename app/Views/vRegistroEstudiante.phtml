<script>
    /* ── Zona de carga de archivos ── */
    function actualizarZona(input) {
        const hint  = document.getElementById('upload-hint');
        const label = document.getElementById('upload-label');
        if (input.files && input.files[0]) {
            hint.textContent = '✅ ' + input.files[0].name;
            label.classList.add('activa');
        } else {
            hint.textContent = 'o arrastra aquí el archivo';
            label.classList.remove('activa');
        }
    }

    /* Drag & Drop visual feedback */
    const zona = document.getElementById('upload-label');
    if (zona) {
        zona.addEventListener('dragover', e => {
            e.preventDefault();
            zona.style.borderColor = 'var(--primary)';
            zona.style.background  = 'rgba(124,58,237,.08)';
        });
        zona.addEventListener('dragleave', () => {
            zona.style.borderColor = '';
            zona.style.background  = '';
        });
        zona.addEventListener('drop', e => {
            e.preventDefault();
            const file = e.dataTransfer.files[0];
            if (file && file.name.toLowerCase().endsWith('.csv')) {
                const dt = new DataTransfer();
                dt.items.add(file);
                const input = document.getElementById('archivo');
                input.files = dt.files;
                actualizarZona(input);
            }
            zona.style.borderColor = '';
            zona.style.background  = '';
        });
    }
</script>

