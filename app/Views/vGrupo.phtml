<script>
    /* ── Gestión de modales (misma lógica que vMateria) ── */
    function openModal(id) {
        document.getElementById(id).classList.add('open');
        const firstInput = document.querySelector('#' + id + ' input[type="text"], #' + id + ' select');
        if (firstInput) setTimeout(() => firstInput.focus(), 50);
    }

    function closeModal(id) {
        document.getElementById(id).classList.remove('open');
    }

    document.querySelectorAll('.overlay').forEach(ov => {
        ov.addEventListener('click', e => {
            if (e.target === ov) closeModal(ov.id);
        });
    });

    document.addEventListener('keydown', e => {
        if (e.key === 'Escape') {
            document.querySelectorAll('.overlay.open').forEach(ov => closeModal(ov.id));
        }
    });

    /* ── Abrir modal de edición pre-cargado ── */
    function openEditModal(id, nombre, ciclo, materiaId) {
        document.getElementById('edit-id').value      = id;
        document.getElementById('edit-nombre').value  = nombre;
        document.getElementById('edit-ciclo').value   = ciclo;
        document.getElementById('edit-materia').value = materiaId;
        openModal('modal-editar');
    }

    /* ── Re-abrir modal si hubo error en crear/editar ── */
    <?php if (!empty($error) && isset($_POST['nombre'])): ?>
        <?php if ($accion === 'crear'): ?>
            window.addEventListener('DOMContentLoaded', () => {
                openModal('modal-crear');
                document.getElementById('crear-nombre').value   = '<?php echo htmlspecialchars(addslashes($_POST['nombre'] ?? '')); ?>';
                document.getElementById('crear-ciclo').value    = '<?php echo htmlspecialchars(addslashes($_POST['ciclo']   ?? '')); ?>';
                document.getElementById('crear-materia').value  = '<?php echo (int)($_POST['materia_id'] ?? 0); ?>';
            });
        <?php elseif ($accion === 'editar'): ?>
            window.addEventListener('DOMContentLoaded', () => {
                openEditModal(
                    <?php echo (int)($_POST['id']         ?? 0); ?>,
                    '<?php echo htmlspecialchars(addslashes($_POST['nombre']     ?? '')); ?>',
                    '<?php echo htmlspecialchars(addslashes($_POST['ciclo']      ?? '')); ?>',
                    <?php echo (int)($_POST['materia_id'] ?? 0); ?>
                );
            });
        <?php endif; ?>
    <?php endif; ?>
</script>

