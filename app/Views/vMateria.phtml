            </div>
        </form>
    </div>
</div>

<script>
    /* ── Gestión de modales ── */
    function openModal(id) {
        document.getElementById(id).classList.add('open');
        const firstInput = document.querySelector('#' + id + ' input[type="text"]');
        if (firstInput) setTimeout(() => firstInput.focus(), 50);
    }

    function closeModal(id) {
        document.getElementById(id).classList.remove('open');
    }

    // Cerrar overlay al hacer clic fuera del modal
    document.querySelectorAll('.overlay').forEach(ov => {
        ov.addEventListener('click', e => {
            if (e.target === ov) closeModal(ov.id);
        });
    });

    // Cerrar con tecla Escape
    document.addEventListener('keydown', e => {
        if (e.key === 'Escape') {
            document.querySelectorAll('.overlay.open').forEach(ov => {
                closeModal(ov.id);
            });
        }
    });

    /* ── Abrir modal de edición precargado ── */
    function openEditModal(id, nombre) {
        document.getElementById('edit-id').value    = id;
        document.getElementById('edit-nombre').value = nombre;
        openModal('modal-editar');
    }

    /* Si hubo error en crear/editar, reabrir el modal correspondiente */
    <?php if (!empty($error) && isset($_POST['nombre'])): ?>
        <?php if ($accion === 'crear'): ?>
            window.addEventListener('DOMContentLoaded', () => openModal('modal-crear'));
            document.getElementById('crear-nombre').value = '<?php echo htmlspecialchars(addslashes($_POST['nombre'] ?? '')); ?>';
        <?php elseif ($accion === 'editar'): ?>
            window.addEventListener('DOMContentLoaded', () => openEditModal(
                <?php echo (int)($_POST['id'] ?? 0); ?>,
                '<?php echo htmlspecialchars(addslashes($_POST['nombre'] ?? '')); ?>'
            ));
        <?php endif; ?>
    <?php endif; ?>
</script>

